    "title": "Sigenergy",
    "titleLang": {
      "en": "Sigenergy Solar System",
      "de": "Sigenergy Solaranlage"
    },
    "desc": {
      "en": "Adapter for Sigenergy solar energy systems (Hybrid Inverter, Battery, AC/DC Charger) via Modbus TCP/RTU",
      "de": "Adapter für Sigenergy Solarenergieanlagen (Hybrid Wechselrichter, Batterie, AC/DC Ladegerät) via Modbus TCP/RTU"
    },
    "authors": [
      "ioBroker Community"
    ],
    "keywords": [
      "sigenergy",
      "solar",
      "modbus",
      "energy",
      "inverter",
      "battery",
      "pv"
    ],
    "platform": "Javascript/Node.js",
    "main": "main.js",
    "icon": "sigenergy.png",
    "extIcon": "https://raw.githubusercontent.com/ssbingo/ioBroker.sigenergy/main/admin/sigenergy.png",
    "enabled": true,
    "readme": "https://github.com/ssbingo/ioBroker.sigenergy/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "energy",
    "compact": true,
    "adminUI": {
      "config": "html"
    },
    "adminTab": {
      "singleton": true,
      "name": {
        "en": "Sigenergy",
        "de": "Sigenergy"
      },
      "link": "%web_protocol%://%ip%:%web_port%/adapter/sigenergy/index.html",
      "fa-icon": "sun-o"
    },
    "supportCustoms": false,
    "schedule": "",
    "subscribable": false,
    "allowInit": true,
    "supportedMessages": {
      "custom": true
    },
    "tier": 2,
    "connectionType": "local",
    "dataSource": "poll",
    "dependencies": [
      {
        "js-controller": ">=6.0.11"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=7.6.17"
      }
    ],
    "licenseInformation": {
      "license": "MIT",
      "type": "free"
    }
  },
  "native": {
    "connectionType": "tcp",
    "tcpHost": "192.168.1.100",
    "tcpPort": 502,
    "serialPort": "/dev/ttyUSB0",
    "serialBaudRate": 9600,
    "serialDataBits": 8,
    "serialParity": "none",
    "serialStopBits": 1,
    "plantId": 247,
    "inverterId": 1,
    "acChargerId": 2,
    "dcChargerId": 3,
    "pollInterval": 10000,
    "timeout": 5000,
    "hasAcCharger": false,
    "hasDcCharger": false,
    "hasBattery": true,
    "hasPv": true,
    "calcBatteryTimeToFull": true,
    "calcBatteryTimeRemaining": true,
    "calcBatteryDailyFull": true,
    "calcBatteryCoverageTime": true,
    "calcSelfConsumptionRate": true,
    "calcAutarkyRate": true,
    "calcPvYield": true,
    "calcGridFeedIn": true
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connection status",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
