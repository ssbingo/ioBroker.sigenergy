{
  "type": "tabs",
  "items": {
    "components": {
      "type": "panel",
      "label": "Components",
      "items": {
        "_componentsHeader": {
          "type": "staticText",
          "text": "Select which components are installed in your Sigenergy system.",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "hasBattery": {
          "type": "checkbox",
          "label": "Battery / ESS",
          "help": "Energy Storage System",
          "default": true,
          "sm": 12,
          "md": 6,
          "lg": 3,
          "xs": 12,
          "xl": 3
        },
        "hasPv": {
          "type": "checkbox",
          "label": "PV Panels",
          "help": "Photovoltaic solar panels",
          "default": true,
          "sm": 12,
          "md": 6,
          "lg": 3,
          "xs": 12,
          "xl": 3
        },
        "hasAcCharger": {
          "type": "checkbox",
          "label": "AC Charger (EVAC)",
          "help": "Sigen EVAC EV charging station",
          "default": false,
          "sm": 12,
          "md": 6,
          "lg": 3,
          "xs": 12,
          "xl": 3
        },
        "hasDcCharger": {
          "type": "checkbox",
          "label": "DC Charger",
          "help": "DC fast charging (via inverter)",
          "default": false,
          "sm": 12,
          "md": 6,
          "lg": 3,
          "xs": 12,
          "xl": 3
        },
        "hasSigenMicro": {
          "type": "checkbox",
          "label": "SigenMicro Micro-Inverter",
          "help": "Sigenergy SigenMicro module-level power electronics (MLPE). Activates the SigenMicro scan & configuration tab.",
          "default": false,
          "sm": 12,
          "md": 6,
          "lg": 3,
          "xs": 12,
          "xl": 3
        },
        "_divider1": {
          "type": "divider",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "acChargerId": {
          "type": "number",
          "label": "AC Charger Modbus ID",
          "help": "Modbus address of the EVAC charger",
          "min": 1,
          "max": 246,
          "default": 2,
          "hidden": "!data.hasAcCharger",
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        },
        "_divider2": {
          "type": "divider",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "pollInterval": {
          "type": "number",
          "label": "Poll Interval (ms)",
          "help": "How often to read Modbus registers. Minimum: 5000 ms",
          "min": 5000,
          "max": 60000,
          "step": 1000,
          "default": 10000,
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        },
        "timeout": {
          "type": "number",
          "label": "Connection Timeout (ms)",
          "help": "Modbus request timeout before failure",
          "min": 1000,
          "max": 30000,
          "step": 1000,
          "default": 5000,
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        }
      }
    },
    "connection": {
      "type": "panel",
      "label": "Connection",
      "items": {
        "connectionType": {
          "type": "select",
          "label": "Connection Type",
          "default": "tcp",
          "options": [
            {
              "value": "tcp",
              "label": "TCP / Ethernet"
            },
            {
              "value": "serial",
              "label": "Serial / RS485"
            }
          ],
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        },
        "_divider_conn": {
          "type": "divider",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "tcpHost": {
          "type": "text",
          "label": "Host / IP Address",
          "placeholder": "192.168.1.100",
          "default": "192.168.1.100",
          "hidden": "data.connectionType !== 'tcp'",
          "sm": 12,
          "md": 5,
          "xs": 12,
          "lg": 5,
          "xl": 5
        },
        "tcpPort": {
          "type": "number",
          "label": "Port",
          "min": 1,
          "max": 65535,
          "default": 502,
          "hidden": "data.connectionType !== 'tcp'",
          "sm": 12,
          "md": 3,
          "xs": 12,
          "lg": 3,
          "xl": 3
        },
        "plantId": {
          "type": "number",
          "label": "Plant Modbus ID",
          "help": "Default: 247 (0xF7)",
          "min": 1,
          "max": 247,
          "default": 247,
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        },
        "inverterId": {
          "type": "number",
          "label": "Inverter Modbus ID",
          "help": "Default: 1",
          "min": 1,
          "max": 246,
          "default": 1,
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        },
        "serialPort": {
          "type": "text",
          "label": "Serial Port",
          "placeholder": "/dev/ttyUSB0",
          "default": "/dev/ttyUSB0",
          "hidden": "data.connectionType !== 'serial'",
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        },
        "serialBaudRate": {
          "type": "select",
          "label": "Baud Rate",
          "default": 9600,
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": 9600,
              "label": "9600 (default)"
            },
            {
              "value": 19200,
              "label": "19200"
            },
            {
              "value": 38400,
              "label": "38400"
            },
            {
              "value": 115200,
              "label": "115200"
            }
          ],
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        },
        "serialDataBits": {
          "type": "select",
          "label": "Data Bits",
          "default": 8,
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": 8,
              "label": "8"
            },
            {
              "value": 7,
              "label": "7"
            }
          ],
          "sm": 12,
          "md": 2,
          "xs": 12,
          "lg": 2,
          "xl": 2
        },
        "serialParity": {
          "type": "select",
          "label": "Parity",
          "default": "none",
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "even",
              "label": "Even"
            },
            {
              "value": "odd",
              "label": "Odd"
            }
          ],
          "sm": 12,
          "md": 2,
          "xs": 12,
          "lg": 2,
          "xl": 2
        },
        "serialStopBits": {
          "type": "select",
          "label": "Stop Bits",
          "default": 1,
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": 1,
              "label": "1"
            },
            {
              "value": 2,
              "label": "2"
            }
          ],
          "sm": 12,
          "md": 2,
          "xs": 12,
          "lg": 2,
          "xl": 2
        },
        "_divider_test": {
          "type": "divider",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_testHeader": {
          "type": "staticText",
          "text": "Connection Test: sends the current settings to the adapter and attempts to read register 30000 (plant system time) via Modbus.",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "test_btn": {
          "type": "sendTo",
          "label": "Test Connection",
          "command": "testConnection",
          "jsonData": true,
          "sm": 12,
          "md": 4,
          "xs": 12,
          "lg": 4,
          "xl": 4
        }
      }
    },
    "sigenmicro": {
      "type": "panel",
      "label": "SigenMicro",
      "hidden": "!data.hasSigenMicro",
      "items": {
        "_microHeader": {
          "type": "staticText",
          "text": "Configure the Modbus slave-ID range to scan for SigenMicro micro-inverters. After scanning, enable each discovered device individually. The adapter polls all enabled devices in every cycle.",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_divider_micro1": {
          "type": "divider",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "sigenMicroScanFrom": {
          "type": "number",
          "label": "Scan — first Modbus ID",
          "help": "Lowest slave address to probe during the SigenMicro device scan (1–246)",
          "min": 1,
          "max": 246,
          "default": 10,
          "sm": 12,
          "md": 3,
          "xs": 12,
          "lg": 3,
          "xl": 3
        },
        "sigenMicroScanTo": {
          "type": "number",
          "label": "Scan — last Modbus ID",
          "help": "Highest slave address to probe during the SigenMicro device scan (1–246)",
          "min": 1,
          "max": 246,
          "default": 30,
          "sm": 12,
          "md": 3,
          "xs": 12,
          "lg": 3,
          "xl": 3
        },
        "_divider_micro2": {
          "type": "divider",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_scanNote": {
          "type": "staticText",
          "text": "Use the SigenMicro tab in the adapter admin page to run the scan and manage discovered devices. The device list and individual enable/disable selections are stored automatically.",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    },
    "statistics": {
      "type": "panel",
      "label": "Statistics",
      "items": {
        "_statsHeader": {
          "type": "staticText",
          "text": "Select which additional statistics should be calculated and written as ioBroker states. These values are derived from live Modbus measurements.",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "calcBatteryTimeToFull": {
          "type": "checkbox",
          "label": "Time to full charge",
          "help": "How long until the battery reaches 100% at current charge rate",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "calcBatteryTimeRemaining": {
          "type": "checkbox",
          "label": "Battery time remaining",
          "help": "How long the battery will last at current consumption",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "calcBatteryDailyFull": {
          "type": "checkbox",
          "label": "Daily charge completion time",
          "help": "Today: how long it took until the battery was fully charged",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "calcBatteryCoverageTime": {
          "type": "checkbox",
          "label": "Battery coverage time today",
          "help": "How long today the battery covered the house consumption without grid",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "calcSelfConsumptionRate": {
          "type": "checkbox",
          "label": "Self-consumption rate",
          "help": "Percentage of PV production used locally (not exported)",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "calcAutarkyRate": {
          "type": "checkbox",
          "label": "Autarky rate",
          "help": "Percentage of house consumption covered by PV + battery",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "calcPvYield": {
          "type": "checkbox",
          "label": "PV yield (15-min average)",
          "help": "Average PV power output over the last 15 minutes",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "calcGridFeedIn": {
          "type": "checkbox",
          "label": "Grid feed-in tracking",
          "help": "Track daily grid export and import energy",
          "default": true,
          "sm": 12,
          "md": 6,
          "xs": 12,
          "lg": 6,
          "xl": 6
        },
        "_divider_derived": {
          "type": "divider",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_derivedInfo": {
          "type": "staticText",
          "text": "Always calculated (cannot be disabled): House Power (PV + Battery discharge − Grid export) · Today max/min SOC · Formatted durations (e.g. \"2h 15m\")",
          "sm": 12,
          "xs": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        }
      }
    }
  },
  "i18n": true
}