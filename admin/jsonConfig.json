{
  "type": "tabs",
  "items": {
    "components": {
      "type": "panel",
      "label": {
        "en": "Components",
        "de": "Komponenten"
      },
      "items": {
        "_componentsHeader": {
          "type": "staticText",
          "text": {
            "en": "Select which components are installed in your Sigenergy system.",
            "de": "Wähle die in deiner Sigenergy-Anlage installierten Komponenten aus."
          },
          "sm": 12
        },
        "hasBattery": {
          "type": "checkbox",
          "label": {
            "en": "Battery / ESS",
            "de": "Batterie / ESS"
          },
          "help": {
            "en": "Energy Storage System",
            "de": "Energiespeichersystem"
          },
          "default": true,
          "sm": 12,
          "md": 6,
          "lg": 3
        },
        "hasPv": {
          "type": "checkbox",
          "label": {
            "en": "PV Panels",
            "de": "PV-Module"
          },
          "help": {
            "en": "Photovoltaic solar panels",
            "de": "Photovoltaik-Solarmodule"
          },
          "default": true,
          "sm": 12,
          "md": 6,
          "lg": 3
        },
        "hasAcCharger": {
          "type": "checkbox",
          "label": {
            "en": "AC Charger (EVAC)",
            "de": "AC-Ladegerät (EVAC)"
          },
          "help": {
            "en": "Sigen EVAC EV charging station",
            "de": "Sigen EVAC Wallbox"
          },
          "default": false,
          "sm": 12,
          "md": 6,
          "lg": 3
        },
        "hasDcCharger": {
          "type": "checkbox",
          "label": {
            "en": "DC Charger",
            "de": "DC-Ladegerät"
          },
          "help": {
            "en": "DC fast charging (via inverter)",
            "de": "DC-Schnellladen (über Wechselrichter)"
          },
          "default": false,
          "sm": 12,
          "md": 6,
          "lg": 3
        },
        "_divider1": {
          "type": "divider",
          "sm": 12
        },
        "acChargerId": {
          "type": "number",
          "label": {
            "en": "AC Charger Modbus ID",
            "de": "AC-Ladegerät Modbus-ID"
          },
          "help": {
            "en": "Modbus address of the EVAC charger",
            "de": "Modbus-Adresse des EVAC-Ladegeräts"
          },
          "min": 1,
          "max": 246,
          "default": 2,
          "hidden": "!data.hasAcCharger",
          "sm": 12,
          "md": 4
        },
        "_divider2": {
          "type": "divider",
          "sm": 12
        },
        "pollInterval": {
          "type": "number",
          "label": {
            "en": "Poll Interval (ms)",
            "de": "Abfrageintervall (ms)"
          },
          "help": {
            "en": "How often to read Modbus registers. Minimum: 5000 ms",
            "de": "Wie oft Modbus-Register gelesen werden. Minimum: 5000 ms"
          },
          "min": 5000,
          "max": 60000,
          "step": 1000,
          "default": 10000,
          "sm": 12,
          "md": 4
        },
        "timeout": {
          "type": "number",
          "label": {
            "en": "Connection Timeout (ms)",
            "de": "Verbindungs-Timeout (ms)"
          },
          "help": {
            "en": "Modbus request timeout before failure",
            "de": "Modbus-Anfrage-Timeout bis zur Fehlermeldung"
          },
          "min": 1000,
          "max": 30000,
          "step": 1000,
          "default": 5000,
          "sm": 12,
          "md": 4
        }
      }
    },
    "connection": {
      "type": "panel",
      "label": {
        "en": "Connection",
        "de": "Verbindung"
      },
      "items": {
        "connectionType": {
          "type": "select",
          "label": {
            "en": "Connection Type",
            "de": "Verbindungstyp"
          },
          "default": "tcp",
          "options": [
            {
              "value": "tcp",
              "label": {
                "en": "TCP / Ethernet",
                "de": "TCP / Ethernet"
              }
            },
            {
              "value": "serial",
              "label": {
                "en": "Serial / RS485",
                "de": "Seriell / RS485"
              }
            }
          ],
          "sm": 12,
          "md": 4
        },
        "_divider_conn": {
          "type": "divider",
          "sm": 12
        },
        "tcpHost": {
          "type": "text",
          "label": {
            "en": "Host / IP Address",
            "de": "Host / IP-Adresse"
          },
          "placeholder": "192.168.1.100",
          "default": "192.168.1.100",
          "hidden": "data.connectionType !== 'tcp'",
          "sm": 12,
          "md": 5
        },
        "tcpPort": {
          "type": "number",
          "label": {
            "en": "Port",
            "de": "Port"
          },
          "min": 1,
          "max": 65535,
          "default": 502,
          "hidden": "data.connectionType !== 'tcp'",
          "sm": 12,
          "md": 3
        },
        "plantId": {
          "type": "number",
          "label": {
            "en": "Plant Modbus ID",
            "de": "Anlage Modbus-ID"
          },
          "help": {
            "en": "Default: 247 (0xF7)",
            "de": "Standard: 247 (0xF7)"
          },
          "min": 1,
          "max": 247,
          "default": 247,
          "sm": 12,
          "md": 4
        },
        "inverterId": {
          "type": "number",
          "label": {
            "en": "Inverter Modbus ID",
            "de": "Wechselrichter Modbus-ID"
          },
          "help": {
            "en": "Default: 1",
            "de": "Standard: 1"
          },
          "min": 1,
          "max": 246,
          "default": 1,
          "sm": 12,
          "md": 4
        },
        "serialPort": {
          "type": "text",
          "label": {
            "en": "Serial Port",
            "de": "Serieller Port"
          },
          "placeholder": "/dev/ttyUSB0",
          "default": "/dev/ttyUSB0",
          "hidden": "data.connectionType !== 'serial'",
          "sm": 12,
          "md": 4
        },
        "serialBaudRate": {
          "type": "select",
          "label": {
            "en": "Baud Rate",
            "de": "Baudrate"
          },
          "default": 9600,
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": 9600,
              "label": "9600 (default)"
            },
            {
              "value": 19200,
              "label": "19200"
            },
            {
              "value": 38400,
              "label": "38400"
            },
            {
              "value": 115200,
              "label": "115200"
            }
          ],
          "sm": 12,
          "md": 4
        },
        "serialDataBits": {
          "type": "select",
          "label": {
            "en": "Data Bits",
            "de": "Datenbits"
          },
          "default": 8,
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": 8,
              "label": "8"
            },
            {
              "value": 7,
              "label": "7"
            }
          ],
          "sm": 12,
          "md": 2
        },
        "serialParity": {
          "type": "select",
          "label": {
            "en": "Parity",
            "de": "Parität"
          },
          "default": "none",
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": "none",
              "label": {
                "en": "None",
                "de": "Keine"
              }
            },
            {
              "value": "even",
              "label": {
                "en": "Even",
                "de": "Gerade"
              }
            },
            {
              "value": "odd",
              "label": {
                "en": "Odd",
                "de": "Ungerade"
              }
            }
          ],
          "sm": 12,
          "md": 2
        },
        "serialStopBits": {
          "type": "select",
          "label": {
            "en": "Stop Bits",
            "de": "Stoppbits"
          },
          "default": 1,
          "hidden": "data.connectionType !== 'serial'",
          "options": [
            {
              "value": 1,
              "label": "1"
            },
            {
              "value": 2,
              "label": "2"
            }
          ],
          "sm": 12,
          "md": 2
        },
        "_divider_test": {
          "type": "divider",
          "sm": 12
        },
        "_testHeader": {
          "type": "staticText",
          "text": {
            "en": "Connection Test: sends the current settings to the adapter and attempts to read register 30000 (plant system time) via Modbus.",
            "de": "Verbindungstest: Sendet die aktuellen Einstellungen an den Adapter und liest Register 30000 (Anlagensystemzeit) per Modbus."
          },
          "sm": 12
        },
        "test_btn": {
          "type": "sendTo",
          "label": {
            "en": "Test Connection",
            "de": "Verbindung testen"
          },
          "command": "testConnection",
          "jsonData": true,
          "sm": 12,
          "md": 4
        }
      }
    },
    "statistics": {
      "type": "panel",
      "label": {
        "en": "Statistics",
        "de": "Statistiken"
      },
      "items": {
        "_statsHeader": {
          "type": "staticText",
          "text": {
            "en": "Select which additional statistics should be calculated and written as ioBroker states. These values are derived from live Modbus measurements.",
            "de": "Wähle, welche zusätzlichen Statistiken berechnet und als ioBroker-Datenpunkte gespeichert werden sollen."
          },
          "sm": 12
        },
        "calcBatteryTimeToFull": {
          "type": "checkbox",
          "label": {
            "en": "Time to full charge",
            "de": "Zeit bis zur vollen Ladung"
          },
          "help": {
            "en": "How long until the battery reaches 100% at current charge rate",
            "de": "Wie lange bis die Batterie bei aktueller Laderate 100% erreicht"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "calcBatteryTimeRemaining": {
          "type": "checkbox",
          "label": {
            "en": "Battery time remaining",
            "de": "Verbleibende Batterielaufzeit"
          },
          "help": {
            "en": "How long the battery will last at current consumption",
            "de": "Wie lange die Batterie bei aktuellem Verbrauch hält"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "calcBatteryDailyFull": {
          "type": "checkbox",
          "label": {
            "en": "Daily charge completion time",
            "de": "Tägliche Vollladezeitpunkt"
          },
          "help": {
            "en": "Today: how long it took until the battery was fully charged",
            "de": "Heute: wie lange es gedauert hat bis die Batterie voll geladen war"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "calcBatteryCoverageTime": {
          "type": "checkbox",
          "label": {
            "en": "Battery coverage time today",
            "de": "Batterie-Abdeckungszeit heute"
          },
          "help": {
            "en": "How long today the battery covered the house consumption without grid",
            "de": "Wie lange die Batterie heute den Hausverbrauch ohne Netz gedeckt hat"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "calcSelfConsumptionRate": {
          "type": "checkbox",
          "label": {
            "en": "Self-consumption rate",
            "de": "Eigenverbrauchsquote"
          },
          "help": {
            "en": "Percentage of PV production used locally (not exported)",
            "de": "Anteil der PV-Produktion der lokal genutzt wird (nicht eingespeist)"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "calcAutarkyRate": {
          "type": "checkbox",
          "label": {
            "en": "Autarky rate",
            "de": "Autarkiequote"
          },
          "help": {
            "en": "Percentage of house consumption covered by PV + battery",
            "de": "Anteil des Hausverbrauchs der durch PV + Batterie gedeckt wird"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "calcPvYield": {
          "type": "checkbox",
          "label": {
            "en": "PV yield (15-min average)",
            "de": "PV-Ertrag (15-Min-Durchschnitt)"
          },
          "help": {
            "en": "Average PV power output over the last 15 minutes",
            "de": "Durchschnittliche PV-Leistung der letzten 15 Minuten"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "calcGridFeedIn": {
          "type": "checkbox",
          "label": {
            "en": "Grid feed-in tracking",
            "de": "Netzeinspeisung erfassen"
          },
          "help": {
            "en": "Track daily grid export and import energy",
            "de": "Tägliche Netzeinspeisung und -bezug erfassen"
          },
          "default": true,
          "sm": 12,
          "md": 6
        },
        "_divider_derived": {
          "type": "divider",
          "sm": 12
        },
        "_derivedInfo": {
          "type": "staticText",
          "text": {
            "en": "Always calculated (cannot be disabled): House Power (PV + Battery discharge − Grid export) · Today max/min SOC · Formatted durations (e.g. \"2h 15m\")",
            "de": "Immer berechnet (nicht deaktivierbar): Hausleistung (PV + Batterieentladung − Netzeinspeisung) · Heutiges Max/Min-SOC · Formatierte Zeitdauern (z.B. \"2h 15m\")"
          },
          "sm": 12
        }
      }
    }
  }
}